public class Main {
    public static void main(String[] args) {
        int[][] matrix = {
            {5, 7, 9},
            {4, 1, 6},
            {7, 3, 20}
        };
        int sum = 0;
        for (int i = 0; i < matrix.length; i++) {
            for (int j = 0; j < matrix[i].length; j++) {
                sum += matrix[i][j];
            }
        }
        System.out.println("Сумма всех элементов матрицы: " + sum);
    }
}
